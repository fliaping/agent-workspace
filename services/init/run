#!/usr/bin/with-contenv bash
echo "[init] Starting initialization..."

# ============================================================
# Homebrew persistence
# Homebrew is installed to /home/linuxbrew/.linuxbrew in image.
# Symlink it to /config/.linuxbrew so user-installed packages
# survive container recreation.
# ============================================================
if [ -d /home/linuxbrew/.linuxbrew ] && [ ! -L /home/linuxbrew/.linuxbrew ]; then
    if [ ! -d /config/.linuxbrew ]; then
        # First run: copy built-in Homebrew to persistent volume
        echo "[init] Copying Homebrew to /config/.linuxbrew (first run)..."
        cp -a /home/linuxbrew/.linuxbrew /config/.linuxbrew
    fi
    # Replace real dir with symlink
    rm -rf /home/linuxbrew/.linuxbrew
    ln -sf /config/.linuxbrew /home/linuxbrew/.linuxbrew
    echo "[init] Homebrew symlinked: /home/linuxbrew/.linuxbrew -> /config/.linuxbrew"
elif [ -L /home/linuxbrew/.linuxbrew ]; then
    # Symlink already exists (container layer preserved), verify target
    if [ ! -d /config/.linuxbrew ]; then
        echo "[init] WARNING: Homebrew symlink exists but /config/.linuxbrew is missing"
    else
        echo "[init] Homebrew persistence OK"
    fi
else
    echo "[init] Homebrew not found, skipping persistence"
fi

# Ensure correct ownership
chown -h abc:abc /home/linuxbrew/.linuxbrew 2>/dev/null || true

# ============================================================
# China mirror configuration
# ============================================================
if [ "$USE_CHINA_MIRROR" = "true" ]; then
    echo "[init] Configuring China mirrors..."
    /usr/local/bin/setup-mirror.sh
else
    echo "[init] Using default mirrors"
fi

echo "[init] Initialization complete!"

# Keep alive — s6 restarts services that exit
exec sleep infinity
