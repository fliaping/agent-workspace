# LinuxServer Webtop + DinD + GPU 加速
# 完整版 Agent 环境
#
# 运行时环境变量：
#   ENABLE_DIND=true|false        - 是否启用 Docker-in-Docker (默认: true)
#   USE_CHINA_MIRROR=true|false   - 是否使用国内软件源 (默认: false)
#   SYSTEM_LANG=zh_CN|en_US       - 系统语言 (默认: zh_CN)
#
# 构建：docker build -f Dockerfile.webtop-full -t my-webtop-full:latest .
# 运行：docker run -d --name webtop-full --privileged -p 3000:3000 my-webtop-full:latest

FROM lscr.io/linuxserver/webtop:ubuntu-xfce

# 设置环境变量默认值（运行时可通过 -e 覆盖）
ENV ENABLE_DIND=true
ENV USE_CHINA_MIRROR=false
ENV SYSTEM_LANG=zh_CN
ENV TZ=Asia/Shanghai
ENV PUID=1000
ENV PGID=1000
ENV DOCKER_TLS_CERTDIR=""

USER root

# 安装所有必要的依赖（构建时完成）
RUN apt-get update && apt-get install -y \
    ca-certificates curl gnupg iptables \
    language-pack-zh-hans language-pack-zh-hans-base \
    fonts-noto-cjk fonts-wqy-zenhei fonts-wqy-microhei \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

# 安装 Docker
RUN curl -fsSL https://get.docker.com | sh

# 配置 Docker daemon
RUN mkdir -p /etc/docker && \
    echo '{"storage-driver":"overlay2","log-driver":"json-file","log-opts":{"max-size":"10m","max-file":"3"}}' > /etc/docker/daemon.json

# 复制外部脚本到容器
COPY scripts/ /usr/local/bin/
COPY services/ /etc/services.d/

# 设置脚本权限
RUN chmod +x /usr/local/bin/*.sh && \
    find /etc/services.d -name "run" -exec chmod +x {} \;

# 添加用户到 docker 组
RUN usermod -aG docker abc

# 创建工作目录
RUN mkdir -p /home/kasm-user/agent-workspace && \
    chown -R 1000:1000 /home/kasm-user/agent-workspace

USER 1000
