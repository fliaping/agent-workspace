#!/usr/bin/with-contenv bash
# s6 service: start all registered systemctl services on container boot.
#
# All operations are idempotent — safe to re-run on s6 restart.
# After work is done, sleep infinity to prevent s6 from re-triggering.

echo "[systemctl-services] Starting..."

if ! command -v systemctl > /dev/null 2>&1; then
    echo "[systemctl-services] systemctl not found, skipping"
    exec sleep infinity
fi

# Wait for Docker daemon (DinD mode only)
if [ "$START_DOCKER" = "true" ] && command -v docker > /dev/null 2>&1; then
    echo "[systemctl-services] Waiting for Docker daemon (max 60s)..."
    for i in $(seq 1 30); do
        if docker info > /dev/null 2>&1; then
            echo "[systemctl-services] Docker ready after $((i * 2))s"
            break
        fi
        [ "$i" -eq 30 ] && echo "[systemctl-services] Docker not ready after 60s, proceeding anyway"
        sleep 2
    done
fi

# Start user-level services (agent onboard wizards create these)
USER_WANTS_DIR="${HOME}/.config/systemd/user/default.target.wants"
if [ -d "$USER_WANTS_DIR" ]; then
    for link in "$USER_WANTS_DIR"/*.service; do
        [ -L "$link" ] || continue
        name=$(basename "$link" .service)
        echo "[systemctl-services] Starting user service: $name"
        systemctl --user start "$name" 2>&1 || true
    done
fi

# Start system-level services (filter known container-incompatible noise)
echo "[systemctl-services] Running: systemctl default"
systemctl default 2>&1 | grep -v -E \
    "seatd|ssl-cert|console-setup|modprobe|/sbin/modprobe|WARNING:|ERROR:" \
    || true

echo "[systemctl-services] Done"

# Keep alive — s6 restarts services that exit
exec sleep infinity
