# LinuxServer Webtop + DinD + GPU 加速 + 完整开发环境
#
# 使用 LinuxServer 原生持久化方式：
# - 挂载 /config 目录即可持久化所有数据
# - 工具路径指向 /config 下的子目录
# - LinuxServer 基础镜像自动处理初始化

FROM lscr.io/linuxserver/webtop:ubuntu-xfce

USER root

# ==========================================
# 环境变量配置
# ==========================================

# 基础配置
ENV ENABLE_DIND=true
ENV USE_CHINA_MIRROR=false
ENV SYSTEM_LANG=zh_CN
ENV TZ=Asia/Shanghai
ENV PUID=1000
ENV PGID=1000
ENV DOCKER_TLS_CERTDIR=""

# 版本
ENV GO_VERSION="go1.22.4"
ENV NODE_VERSION="20"

# 关键：所有工具路径指向 /config（LinuxServer 持久化目录）
ENV HOME=/config
ENV GOROOT=/usr/local/go
ENV GOPATH=/config/go
ENV CARGO_HOME=/config/.cargo
ENV RUSTUP_HOME=/config/.rustup
ENV NPM_CONFIG_PREFIX=/config/.npm-global
ENV PIP_CACHE_DIR=/config/.cache/pip
ENV UV_CACHE_DIR=/config/.cache/uv
ENV HOMEBREW_PREFIX=/config/.linuxbrew

# PATH
ENV PATH=$GOPATH/bin:$CARGO_HOME/bin:$GOROOT/bin:$NPM_CONFIG_PREFIX/bin:/config/.linuxbrew/bin:/config/.linuxbrew/sbin:$PATH

# 国内镜像源
ENV HOMEBREW_BREW_GIT_REMOTE="https://mirrors.ustc.edu.cn/brew.git"
ENV HOMEBREW_CORE_GIT_REMOTE="https://mirrors.ustc.edu.cn/homebrew-core.git"
ENV HOMEBREW_BOTTLE_DOMAIN="https://mirrors.ustc.edu.cn/homebrew-bottles"
ENV HOMEBREW_NO_AUTO_UPDATE=1
ENV UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
ENV GOPROXY=https://goproxy.cn,direct

# ==========================================
# 安装系统依赖
# ==========================================

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl gnupg iptables sudo \
    build-essential git wget jq unzip xz-utils \
    python3 python3-pip python3-venv python3-dev \
    libssl-dev libffi-dev \
    locales fonts-wqy-zenhei fonts-wqy-microhei fonts-noto-cjk \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# 中文 locale
RUN sed -i 's/# zh_CN.UTF-8 UTF-8/zh_CN.UTF-8 UTF-8/' /etc/locale.gen && locale-gen zh_CN.UTF-8

# ==========================================
# 安装开发工具
# ==========================================

# Node.js + NPM + PNPM + PM2
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash - \
    && apt-get install -y nodejs \
    && npm install -g pnpm pm2 typescript \
    && npm config set registry https://registry.npmmirror.com --global \
    && pnpm config set registry https://registry.npmmirror.com \
    && npm cache clean --force \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Go (自动检测架构)
RUN ARCH=$(dpkg --print-architecture) \
    && if [ "$ARCH" = "amd64" ]; then GO_ARCH="linux-amd64"; elif [ "$ARCH" = "arm64" ]; then GO_ARCH="linux-arm64"; fi \
    && curl -fsSL "https://go.dev/dl/${GO_VERSION}.${GO_ARCH}.tar.gz" | tar -xz -C /usr/local

# UV
RUN pip3 install --no-cache-dir uv --break-system-packages

# 系统级镜像源配置
RUN mkdir -p /etc/pip \
    && echo "[global]\nindex-url = https://pypi.tuna.tsinghua.edu.cn/simple" > /etc/pip/pip.conf \
    && mkdir -p /etc/cargo \
    && echo '[source.crates-io]\nreplace-with = "ustc"\n\n[source.ustc]\nregistry = "sparse+https://mirrors.ustc.edu.cn/crates.io-index/"' > /etc/cargo/config.toml

# Docker
RUN curl -fsSL https://get.docker.com | sh

# ==========================================
# KasmVNC 配置
# ==========================================

# 开启 IME 输入法
RUN if [ -f /usr/share/kasmvnc/www/assets/ui-*.js ]; then \
        sed -i 's/initSetting("enable_ime",!1)/initSetting("enable_ime",!0)/' /usr/share/kasmvnc/www/assets/ui-*.js; \
    fi

# VNC 稳定性
RUN mkdir -p /home/kasm-user/.vnc \
    && printf 'logging:\n  log_writer_name: all\n  log_dest: logfile\n  level: 100\n\nuser_session:\n  idle_timeout: 300\n' > /home/kasm-user/.vnc/kasmvnc.yaml

# ==========================================
# 复制脚本和服务
# ==========================================

COPY scripts/ /usr/local/bin/
COPY services/ /etc/services.d/

RUN chmod +x /usr/local/bin/*.sh \
    && find /etc/services.d -name "run" -exec chmod +x {} \;

# 配置 s6 服务依赖（init 先执行，其他服务等待）
RUN mkdir -p /etc/services.d/monitor/dependencies /etc/services.d/docker/dependencies /etc/services.d/docker-ready/dependencies \
    && touch /etc/services.d/monitor/dependencies/init \
    && touch /etc/services.d/docker/dependencies/init \
    && touch /etc/services.d/docker-ready/dependencies/init

# ==========================================
# 权限配置
# ==========================================

RUN echo "abc ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/abc \
    && chmod 0440 /etc/sudoers.d/abc \
    && usermod -aG docker abc

# ==========================================
# 健康检查
# ==========================================

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
    CMD curl -f http://localhost:3000/ || exit 1

# 使用 LinuxServer 原生的 /init 入口
